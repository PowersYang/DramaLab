# ===============================
# 数据库配置
# 推荐优先使用 DATABASE_URL
# ===============================
# DATABASE_URL: 控制后端完整数据库连接串，配置后会优先于 POSTGRES_* 生效。
# DATABASE_URL=postgresql+psycopg://postgres:postgres@127.0.0.1:5432/dramalab
# POSTGRES_HOST: 控制 PostgreSQL 主机地址。
POSTGRES_HOST=127.0.0.1
# POSTGRES_PORT: 控制 PostgreSQL 端口。
POSTGRES_PORT=5432
# POSTGRES_DB: 控制 PostgreSQL 数据库名。
POSTGRES_DB=dramalab
# POSTGRES_SCHEMA: 控制 DramaLab 使用的 PostgreSQL schema。
POSTGRES_SCHEMA=public
# POSTGRES_USER: 控制 PostgreSQL 登录用户名。
POSTGRES_USER=postgres
# POSTGRES_PASSWORD: 控制 PostgreSQL 登录密码。
POSTGRES_PASSWORD=postgres

# 阿里云 DashScope API Key (用于通义千问等模型)
# DASHSCOPE_API_KEY: 控制 DashScope 兼容接口调用的默认 API Key。
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# 阿里云 Access Key (用于 OSS、视频超分等服务)
# ALIBABA_CLOUD_ACCESS_KEY_ID: 控制阿里云 OSS 等能力的 Access Key ID。
ALIBABA_CLOUD_ACCESS_KEY_ID=your_aliyun_access_key_id_here
# ALIBABA_CLOUD_ACCESS_KEY_SECRET: 控制阿里云 OSS 等能力的 Access Key Secret。
ALIBABA_CLOUD_ACCESS_KEY_SECRET=your_aliyun_access_key_secret_here

# OSS 配置 (可选，用于图片/视频存储)
# OSS_BUCKET_NAME: 控制上传资源落到哪个 OSS Bucket。
OSS_BUCKET_NAME=your_bucket_name
# OSS_ENDPOINT: 控制 OSS 所在地域和访问端点。
OSS_ENDPOINT=oss-cn-beijing.aliyuncs.com
# OSS_BASE_PATH: 控制上传到 OSS 后的统一根目录前缀。
OSS_BASE_PATH=comic_gen/
# 前端展示使用的稳定公网地址前缀，建议填写 CDN 域名或 OSS 绑定域名，例如 https://static.example.com
# OSS_PUBLIC_BASE_URL: 控制前端展示媒体时使用的公网 URL 前缀。
OSS_PUBLIC_BASE_URL=

# Kling AI 配置 (可选，用于 Kling 视频生成)
# KLING_ACCESS_KEY: 控制 Kling 供应商鉴权 access_key。
KLING_ACCESS_KEY=your_kling_access_key_here
# KLING_SECRET_KEY: 控制 Kling 供应商鉴权 secret_key。
KLING_SECRET_KEY=your_kling_secret_key_here

# Vidu AI 配置 (可选，用于 Vidu 视频生成)
# VIDU_API_KEY: 控制 Vidu 视频生成供应商 API Key。
VIDU_API_KEY=your_vidu_api_key_here

# 豆包 Ark 配置 (可选，用于 Doubao 视频生成)
# ARK_API_KEY: 控制豆包 Ark / Doubao 供应商 API Key。
ARK_API_KEY=your_ark_api_key_here

# LLM 多模型适配 (可选)
# 默认使用 DashScope (通过 OpenAI 兼容接口调用，只需上方 DASHSCOPE_API_KEY 即可)
# LLM_PROVIDER=dashscope
#
# 如需切换到第三方 OpenAI 兼容 API (OpenAI/DeepSeek/Ollama 等):
# LLM_PROVIDER=openai
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o
#
# DeepSeek 示例:
# LLM_PROVIDER=openai
# OPENAI_API_KEY=your_deepseek_api_key
# OPENAI_BASE_URL=https://api.deepseek.com/v1
# OPENAI_MODEL=deepseek-chat
#
# 本地 Ollama 示例:
# LLM_PROVIDER=openai
# OPENAI_API_KEY=ollama
# OPENAI_BASE_URL=http://localhost:11434/v1
# OPENAI_MODEL=qwen2.5:72b
#
# LLM 请求超时与重试（分镜分析较长时建议适当调大）
# LLM_REQUEST_TIMEOUT_SECONDS=300
# LLM_MAX_RETRIES=1

# API 服务配置
# API_HOST: 控制 FastAPI 服务监听地址。
API_HOST=0.0.0.0
# API_PORT: 控制 FastAPI 服务监听端口。
API_PORT=8000

# ===============================
# API 端点配置 (可选，海外部署时切换到国际端点)
# 命名约定: {PROVIDER}_BASE_URL
# ===============================
# DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com
# KLING_BASE_URL=https://api.klingai.com/v1
# VIDU_BASE_URL=https://api.vidu.cn/ent/v2

DEFAULT_LLM_REQUEST_TIMEOUT_SECONDS=300
DEFAULT_LLM_MAX_RETRIES=1

# 认证与权限
# AUTH_JWT_SECRET: 控制 access token / 邀请 token 等 JWT 的签名密钥。
AUTH_JWT_SECRET=replace-with-a-long-random-secret
# 用于邀请邮件、重置密码等外链跳转，建议填写线上对外访问地址
# AUTH_APP_BASE_URL: 控制邀请邮件、密码重置等外链跳转的站点根地址。
AUTH_APP_BASE_URL=http://localhost:3000
# HTTPS 线上环境建议开启，确保 access/refresh cookie 带 Secure 标记
# AUTH_COOKIE_SECURE: 控制认证 cookie 是否强制带 Secure 标记。
AUTH_COOKIE_SECURE=false
# AUTH_ACCESS_TOKEN_TTL_MINUTES: 控制 access token 的过期分钟数。
AUTH_ACCESS_TOKEN_TTL_MINUTES=30
# AUTH_REFRESH_TOKEN_TTL_DAYS: 控制 refresh session 的绝对过期天数。
AUTH_REFRESH_TOKEN_TTL_DAYS=30
# AUTH_REFRESH_TOKEN_IDLE_TTL_DAYS: 控制 refresh session 的空闲过期天数。
AUTH_REFRESH_TOKEN_IDLE_TTL_DAYS=7
# AUTH_EMAIL_CODE_TTL_MINUTES: 控制邮箱验证码的有效分钟数。
AUTH_EMAIL_CODE_TTL_MINUTES=10
# AUTH_VERIFICATION_CODE_TTL_MINUTES: 控制通用验证码记录的有效分钟数。
AUTH_VERIFICATION_CODE_TTL_MINUTES=10
# AUTH_CAPTCHA_TTL_SECONDS: 控制图形验证码挑战的有效秒数。
AUTH_CAPTCHA_TTL_SECONDS=300
# AUTH_SEND_CODE_COOLDOWN_SECONDS: 控制同一标识两次发码之间的冷却秒数。
AUTH_SEND_CODE_COOLDOWN_SECONDS=60
# AUTH_SEND_CODE_LIMIT_PER_IDENTIFIER_PER_HOUR: 控制同一账号标识每小时最多发码次数。
AUTH_SEND_CODE_LIMIT_PER_IDENTIFIER_PER_HOUR=5
# AUTH_SEND_CODE_LIMIT_PER_IP_PER_HOUR: 控制同一 IP 每小时最多发码次数。
AUTH_SEND_CODE_LIMIT_PER_IP_PER_HOUR=20
# 开发/测试环境可开启验证码回显，生产环境请关闭
# AUTH_EXPOSE_TEST_CODE: 控制是否在接口响应里直接回显验证码，仅开发/测试可用。
AUTH_EXPOSE_TEST_CODE=false
# SMTP 邮件发送（配置后才会真的给邮箱发验证码）
# AUTH_EMAIL_SMTP_HOST: 控制验证码邮件走哪个 SMTP 服务器。
AUTH_EMAIL_SMTP_HOST=smtp.qq.com
# AUTH_EMAIL_SMTP_PORT: 控制 SMTP 端口。
AUTH_EMAIL_SMTP_PORT=587
# AUTH_EMAIL_SMTP_USER: 控制 SMTP 登录账号。
AUTH_EMAIL_SMTP_USER=your_sender@qq.com
# AUTH_EMAIL_SMTP_PASSWORD: 控制 SMTP 登录密码或授权码。
AUTH_EMAIL_SMTP_PASSWORD=your_smtp_authorization_code
# AUTH_EMAIL_FROM: 控制验证码邮件的发件人地址。
AUTH_EMAIL_FROM=your_sender@qq.com
# AUTH_EMAIL_SMTP_TLS: 控制 SMTP 是否启用 STARTTLS。
AUTH_EMAIL_SMTP_TLS=true
# AUTH_EMAIL_SMTP_SSL: 控制 SMTP 是否直连 SSL。
AUTH_EMAIL_SMTP_SSL=false
# AUTH_SMS_PROVIDER: 控制短信验证码发送实现，disabled 表示关闭，mock 表示测试，webhook 表示转发到外部网关。
AUTH_SMS_PROVIDER=
# AUTH_SMS_WEBHOOK_URL: 控制短信 webhook 模式下的目标接口地址。
AUTH_SMS_WEBHOOK_URL=
# AUTH_SMS_WEBHOOK_TOKEN: 控制短信 webhook 模式下的鉴权 token。
AUTH_SMS_WEBHOOK_TOKEN=
# 可选：配置平台超级管理员邮箱，多个用英文逗号分隔
# AUTH_PLATFORM_SUPER_ADMIN_EMAILS: 控制哪些邮箱在登录后具备平台超级管理员身份。
AUTH_PLATFORM_SUPER_ADMIN_EMAILS=admin@example.com

# 支付 provider 模式
# 当前内置 mock，真实支付接入完成前请保持 mock
# PAYMENT_PROVIDER_MODE: 控制支付链路当前使用 mock 还是真实 provider 模式。
PAYMENT_PROVIDER_MODE=mock
# 真实支付模式下，回调基地址需要能被微信支付 / 支付宝公网访问。
# PAYMENT_NOTIFY_BASE_URL: 控制支付渠道回调通知的公网根地址，例如 https://api.example.com
PAYMENT_NOTIFY_BASE_URL=
# 可选：如需走沙箱或代理，可覆盖 API 基地址。
WECHAT_PAY_BASE_URL=https://api.mch.weixin.qq.com
ALIPAY_GATEWAY_URL=https://openapi.alipay.com/gateway.do

# 微信支付（Native 扫码）配置
# WECHAT_PAY_APP_ID: 控制微信支付应用 appid。
WECHAT_PAY_APP_ID=
# WECHAT_PAY_MCH_ID: 控制微信支付商户号。
WECHAT_PAY_MCH_ID=
# WECHAT_PAY_MCH_SERIAL_NO: 控制微信支付商户证书序列号。
WECHAT_PAY_MCH_SERIAL_NO=
# WECHAT_PAY_PRIVATE_KEY_PATH: 控制微信支付商户私钥文件路径。
WECHAT_PAY_PRIVATE_KEY_PATH=
# WECHAT_PAY_API_V3_KEY: 控制微信支付 APIv3 密钥。
WECHAT_PAY_API_V3_KEY=
# WECHAT_PAY_PLATFORM_CERT_PATH: 控制微信支付平台证书 PEM 文件路径，用于回调验签。
WECHAT_PAY_PLATFORM_CERT_PATH=

# 支付宝（当面付 / 预下单）配置
# ALIPAY_APP_ID: 控制支付宝应用 app_id。
ALIPAY_APP_ID=
# ALIPAY_APP_PRIVATE_KEY_PATH: 控制支付宝应用私钥文件路径。
ALIPAY_APP_PRIVATE_KEY_PATH=
# ALIPAY_PUBLIC_KEY_PATH: 控制支付宝公钥文件路径。
ALIPAY_PUBLIC_KEY_PATH=
