# ===============================
# 数据库配置
# 推荐优先使用 DATABASE_URL
# ===============================
# DATABASE_URL=postgresql+psycopg://postgres:postgres@127.0.0.1:5432/lumenx
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=lumenx
POSTGRES_SCHEMA=public
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# 阿里云 DashScope API Key (用于通义千问等模型)
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# 阿里云 Access Key (用于 OSS、视频超分等服务)
ALIBABA_CLOUD_ACCESS_KEY_ID=your_aliyun_access_key_id_here
ALIBABA_CLOUD_ACCESS_KEY_SECRET=your_aliyun_access_key_secret_here

# OSS 配置 (可选，用于图片/视频存储)
OSS_BUCKET_NAME=your_bucket_name
OSS_ENDPOINT=oss-cn-beijing.aliyuncs.com
OSS_BASE_PATH=comic_gen/
# 前端展示使用的稳定公网地址前缀，建议填写 CDN 域名或 OSS 绑定域名，例如 https://static.example.com
OSS_PUBLIC_BASE_URL=

# Kling AI 配置 (可选，用于 Kling 视频生成)
KLING_ACCESS_KEY=your_kling_access_key_here
KLING_SECRET_KEY=your_kling_secret_key_here

# Vidu AI 配置 (可选，用于 Vidu 视频生成)
VIDU_API_KEY=your_vidu_api_key_here

# 豆包 Ark 配置 (可选，用于 Doubao 视频生成)
ARK_API_KEY=your_ark_api_key_here

# LLM 多模型适配 (可选)
# 默认使用 DashScope (通过 OpenAI 兼容接口调用，只需上方 DASHSCOPE_API_KEY 即可)
# LLM_PROVIDER=dashscope
#
# 如需切换到第三方 OpenAI 兼容 API (OpenAI/DeepSeek/Ollama 等):
# LLM_PROVIDER=openai
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o
#
# DeepSeek 示例:
# LLM_PROVIDER=openai
# OPENAI_API_KEY=your_deepseek_api_key
# OPENAI_BASE_URL=https://api.deepseek.com/v1
# OPENAI_MODEL=deepseek-chat
#
# 本地 Ollama 示例:
# LLM_PROVIDER=openai
# OPENAI_API_KEY=ollama
# OPENAI_BASE_URL=http://localhost:11434/v1
# OPENAI_MODEL=qwen2.5:72b
#
# LLM 请求超时与重试（分镜分析较长时建议适当调大）
# LLM_REQUEST_TIMEOUT_SECONDS=300
# LLM_MAX_RETRIES=1

# API 服务配置
API_HOST=0.0.0.0
API_PORT=8000

# ===============================
# API 端点配置 (可选，海外部署时切换到国际端点)
# 命名约定: {PROVIDER}_BASE_URL
# ===============================
# DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com
# KLING_BASE_URL=https://api.klingai.com/v1
# VIDU_BASE_URL=https://api.vidu.cn/ent/v2

DEFAULT_LLM_REQUEST_TIMEOUT_SECONDS=300
DEFAULT_LLM_MAX_RETRIES=1

# 认证与权限
AUTH_JWT_SECRET=replace-with-a-long-random-secret
AUTH_ACCESS_TOKEN_TTL_MINUTES=30
AUTH_REFRESH_TOKEN_TTL_DAYS=30
AUTH_EMAIL_CODE_TTL_MINUTES=10
# 开发/测试环境可开启验证码回显，生产环境请关闭
AUTH_EXPOSE_TEST_CODE=true
# 可选：配置平台超级管理员邮箱，多个用英文逗号分隔
AUTH_PLATFORM_SUPER_ADMIN_EMAILS=admin@example.com
